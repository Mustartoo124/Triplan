# === LLM Provider ===
OPENAI_API_KEY=sk-xxx
LLM_MODEL=gpt-4o

# === Neo4j Knowledge Graph ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# === Web Search (SerpAPI or Tavily) ===
SEARCH_API_KEY=xxx
SEARCH_PROVIDER=tavily

# === Geocoding (Google Maps) ===
GOOGLE_MAPS_API_KEY=xxx

# === App Settings ===
APP_ENV=development
LOG_LEVEL=INFO
DATA_DIR=./data
